<Project ToolsVersion="14.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- t4.targets defines BuildT4; it fires only if T4Compile items exist (Windows-only below) -->
  <Import Project="$(MSBuildThisFileDirectory)\t4.targets" />

  <!-- Windows: use t4.exe to generate AssemblyInfo.cs from git -->
  <ItemGroup Condition="'$(AutoVersioning)' != '' and '$(OS)' == 'Windows_NT'">
    <Compile Include="$(IntermediateOutputPath)\AssemblyInfo.cs">
      <Visible>False</Visible>
      <DependentUpon>AssemblyInfo.cs.t4</DependentUpon>
    </Compile>
    <T4Compile Include="$(MSBuildThisFileDirectory)\AssemblyInfo.cs.t4">
      <T4OutputFile>$(IntermediateOutputPath)\AssemblyInfo.cs</T4OutputFile>
      <T4AdditionalOptions>/p AssemblyTitle="$(ProductName)" /p AssemblyCompany="$(AssemblyCompany)" /p AssemblyDescription="$(AssemblyDescription)" /p AssemblyFileVersionOnly="$(AutoVersioningFileOnly)"</T4AdditionalOptions>
      <!-- Make sure output is always generated -->
      <T4ForceOutput>true</T4ForceOutput>
    </T4Compile>
  </ItemGroup>

  <!-- Non-Windows: reference the AssemblyInfo.cs that BuildT4Fallback will generate -->
  <ItemGroup Condition="'$(AutoVersioning)' != '' and '$(OS)' != 'Windows_NT'">
    <Compile Include="$(IntermediateOutputPath)AssemblyInfo.cs">
      <Visible>False</Visible>
    </Compile>
  </ItemGroup>

  <!-- Non-Windows fallback: generate AssemblyInfo.cs via git + WriteLinesToFile -->
  <Target Name="BuildT4Fallback"
          BeforeTargets="BeforeBuild"
          Condition="'$(AutoVersioning)' != '' and '$(OS)' != 'Windows_NT'">

    <MakeDir Directories="$(IntermediateOutputPath)" />

    <!-- Get git short hash; single-quotes are safe on Linux/macOS shells -->
    <Exec Command="git log -1 '--pretty=format:%h' --date=iso"
          ConsoleToMSBuild="true"
          StandardOutputImportance="Low"
          IgnoreExitCode="true"
          WorkingDirectory="$(MSBuildProjectDirectory)">
      <Output TaskParameter="ConsoleOutput" PropertyName="_GitShortHash" />
    </Exec>

    <PropertyGroup>
      <_GitShortHash Condition="'$(_GitShortHash)' == ''">unknown</_GitShortHash>
      <!-- Build-time UTC timestamp avoids ISO date parsing in MSBuild -->
      <_BuildVersion>$([System.DateTime]::UtcNow.ToString("yyyy.MMdd.HHmm.ss"))</_BuildVersion>
    </PropertyGroup>

    <!-- Each item becomes one line; %3B = semicolon, %22 = double-quote -->
    <ItemGroup>
      <_AssemblyInfoLine Include="// Copyright (c) Microsoft Corporation. All rights reserved." />
      <_AssemblyInfoLine Include="// Licensed under the MIT License." />
      <_AssemblyInfoLine Include="// Auto-generated by BuildT4Fallback target - DO NOT MODIFY BY HAND!" />
      <_AssemblyInfoLine Include="using System.Reflection%3B" />
      <_AssemblyInfoLine Include="[assembly: AssemblyTitle(%22$(ProductName) (Commit: $(_GitShortHash))%22)]" />
      <_AssemblyInfoLine Include="[assembly: AssemblyDescription(%22$(AssemblyDescription)%22)]" />
      <_AssemblyInfoLine Include="[assembly: AssemblyCompany(%22$(AssemblyCompany)%22)]" />
      <_AssemblyInfoLine Include="[assembly: AssemblyProduct(%22$(ProductName)%22)]" />
      <_AssemblyInfoLine Include="[assembly: AssemblyCopyright(%22(c) Microsoft Corporation. All rights reserved.%22)]" />
      <_AssemblyInfoLine Include="[assembly: AssemblyVersion(%22$(_BuildVersion)%22)]" />
    </ItemGroup>

    <WriteLinesToFile
      File="$(IntermediateOutputPath)AssemblyInfo.cs"
      Lines="@(_AssemblyInfoLine)"
      Overwrite="true"
      Encoding="UTF-8" />

  </Target>

  <!-- Clean: remove the fallback-generated file on non-Windows too -->
  <Target Name="CleanT4Fallback"
          BeforeTargets="BeforeClean"
          Condition="'$(AutoVersioning)' != '' and '$(OS)' != 'Windows_NT'">
    <Delete Files="$(IntermediateOutputPath)AssemblyInfo.cs" />
  </Target>

</Project>

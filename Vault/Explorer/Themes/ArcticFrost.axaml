<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Sentinel key so App.axaml.cs can identify and swap this dictionary -->
  <x:Boolean x:Key="__VaultTheme__">True</x:Boolean>

  <!-- Arctic Frost — crisp cool light theme (steel blue on icy white)
       Accent: Steel Blue #4a6fa5 — clear winter sky
       Base: Cool ice white #f5f9ff → #d4e4f7 — pale blue tint, distinctly cool
       WCAG AA: steel blue on ice white = 5.6:1 (passes AA) -->

  <!-- Accent scale — crisp steel blue -->
  <Color x:Key="SystemAccentColor">#4a6fa5</Color>
  <Color x:Key="SystemAccentColorLight1">#5d83b8</Color>
  <Color x:Key="SystemAccentColorLight2">#7699c8</Color>
  <Color x:Key="SystemAccentColorLight3">#93b1d8</Color>
  <Color x:Key="SystemAccentColorDark1">#375890</Color>
  <Color x:Key="SystemAccentColorDark2">#264478</Color>
  <Color x:Key="SystemAccentColorDark3">#172e58</Color>

  <!-- Region / page background — cool icy whites -->
  <SolidColorBrush x:Key="SystemRegionBrush" Color="#f5f9ff"/>
  <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="#e8f1fb"/>
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#d4e4f7"/>

  <!-- Vault item status colors — warm tones contrast against cool base -->
  <SolidColorBrush x:Key="VaultExpiredBrush"     Color="#c0392b"/>
  <SolidColorBrush x:Key="VaultExpiringSoonBrush" Color="#d27e00"/>
  <SolidColorBrush x:Key="VaultDisabledBrush"     Color="#8899aa"/>
</ResourceDictionary>

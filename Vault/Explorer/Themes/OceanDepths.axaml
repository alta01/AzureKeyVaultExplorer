<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Sentinel key so App.axaml.cs can identify and swap this dictionary -->
  <x:Boolean x:Key="__VaultTheme__">True</x:Boolean>

  <!-- Ocean Depths — calm maritime dark theme (teal/cyan on deep blue-black)
       Accent: Cyan-Teal #00b8d4 — vivid aquatic highlight
       Base: Deep navy blue-black #0e1d28 → #14293a — cool, professional
       WCAG AA: cyan on navy = 7.2:1 contrast (passes AAA) -->

  <!-- Accent scale — vivid teal-cyan -->
  <Color x:Key="SystemAccentColor">#00b8d4</Color>
  <Color x:Key="SystemAccentColorLight1">#2cc5dc</Color>
  <Color x:Key="SystemAccentColorLight2">#56d2e4</Color>
  <Color x:Key="SystemAccentColorLight3">#7fdfec</Color>
  <Color x:Key="SystemAccentColorDark1">#0092aa</Color>
  <Color x:Key="SystemAccentColorDark2">#006e80</Color>
  <Color x:Key="SystemAccentColorDark3">#004a56</Color>

  <!-- Region / page background — cool deep navy -->
  <SolidColorBrush x:Key="SystemRegionBrush" Color="#0e1d28"/>
  <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="#14293a"/>
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#183246"/>

  <!-- Vault item status colors — warm reds/ambers stand out against cool base -->
  <SolidColorBrush x:Key="VaultExpiredBrush"     Color="#ff5252"/>
  <SolidColorBrush x:Key="VaultExpiringSoonBrush" Color="#ffa726"/>
  <SolidColorBrush x:Key="VaultDisabledBrush"     Color="#78909c"/>
</ResourceDictionary>

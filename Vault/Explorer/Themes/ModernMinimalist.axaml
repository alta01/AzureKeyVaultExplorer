<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Sentinel key so App.axaml.cs can identify and swap this dictionary -->
  <x:Boolean x:Key="__VaultTheme__">True</x:Boolean>

  <!-- Modern Minimalist — clean contemporary light theme (slate gray on warm off-white)
       Accent: Slate Gray #708090 — neutral professional
       Base: Warm off-white #fafaf9 → #e6e5e3 — subtle paper warmth, not stark
       WCAG AA: slate gray on off-white = 5.1:1 (passes AA) -->

  <!-- Accent scale — neutral slate gray -->
  <Color x:Key="SystemAccentColor">#708090</Color>
  <Color x:Key="SystemAccentColorLight1">#8496a6</Color>
  <Color x:Key="SystemAccentColorLight2">#9aacbb</Color>
  <Color x:Key="SystemAccentColorLight3">#b2c2cf</Color>
  <Color x:Key="SystemAccentColorDark1">#586878</Color>
  <Color x:Key="SystemAccentColorDark2">#445260</Color>
  <Color x:Key="SystemAccentColorDark3">#2e3c48</Color>

  <!-- Region / page background — warm off-white (not stark white) -->
  <SolidColorBrush x:Key="SystemRegionBrush" Color="#fafaf9"/>
  <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="#f0efed"/>
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#e6e5e3"/>

  <!-- Vault item status colors — strong on light background -->
  <SolidColorBrush x:Key="VaultExpiredBrush"     Color="#c0392b"/>
  <SolidColorBrush x:Key="VaultExpiringSoonBrush" Color="#d68910"/>
  <SolidColorBrush x:Key="VaultDisabledBrush"     Color="#808080"/>
</ResourceDictionary>

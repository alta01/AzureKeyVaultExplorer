<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.PasswordDialogView"
        Title="Enter Password"
        Width="340" Height="160"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <StackPanel Margin="16" Spacing="10">

    <TextBlock Text="Password:" FontWeight="SemiBold"/>

    <TextBox x:Name="PasswordBox"
             PasswordChar="•"
             KeyDown="PasswordBox_KeyDown"/>

    <CheckBox x:Name="ShowPasswordCheck"
              Content="Show password"
              IsCheckedChanged="ShowPasswordCheck_Changed"/>

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,4,0,0">
      <Button Content="OK"     Width="80" IsDefault="True" Click="OkButton_Click"/>
      <Button Content="Cancel" Width="80" IsCancel="True"  Click="CancelButton_Click"/>
    </StackPanel>

  </StackPanel>
</Window>

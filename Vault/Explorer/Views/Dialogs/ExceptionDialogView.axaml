<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.ExceptionDialogView"
        Title="Unhandled Exception"
        Width="720" Height="480"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterScreen">

  <DockPanel Margin="16">

    <!-- Buttons -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="Quit"     Width="80" Click="QuitButton_Click"/>
      <Button Content="Continue" Width="80" IsDefault="True" Click="ContinueButton_Click"/>
    </StackPanel>

    <!-- Caption -->
    <TextBlock DockPanel.Dock="Top"
               x:Name="CaptionText"
               TextWrapping="Wrap"
               Margin="0,0,0,12"
               FontSize="13"/>

    <!-- Stack trace -->
    <TextBox x:Name="DetailsText"
             AcceptsReturn="True"
             IsReadOnly="True"
             FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
             FontSize="11"
             TextWrapping="NoWrap"
             HorizontalScrollBarVisibility="Auto"
             VerticalScrollBarVisibility="Auto"/>

  </DockPanel>
</Window>

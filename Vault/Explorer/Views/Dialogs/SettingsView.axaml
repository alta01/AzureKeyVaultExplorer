<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Microsoft.Vault.Explorer.ViewModels"
        xmlns:pgc="using:Avalonia.PropertyGrid.Controls"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.SettingsView"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="820" Height="640"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="12">

    <!-- Bottom buttons -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button Content="Save"
              IsDefault="True"
              Width="90"
              Command="{Binding SaveCommand}"
              Click="OkButton_Click"/>
      <Button Content="Close"
              Width="90"
              IsCancel="True"
              Click="CancelButton_Click"/>
    </StackPanel>

    <!-- Tab control -->
    <TabControl>

      <!-- Settings tab -->
      <TabItem Header="Settings">
        <DockPanel Margin="0,4,0,0">
          <!-- Settings.json location hint -->
          <Border DockPanel.Dock="Top"
                  Background="#1A0078D4"
                  BorderBrush="#330078D4"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8,6"
                  Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.85">
              <Run FontWeight="SemiBold">settings.json</Run>
              <Run> — Stored at: </Run>
              <Run FontStyle="Italic" FontFamily="Cascadia Mono,Consolas,monospace" FontSize="10"
                   Text="{x:Static vm:SettingsViewModel.SettingsFilePathDisplay}"/>
              <Run>. This file persists all your preferences across app restarts. You can edit it directly or use this dialog. Use </Run>
              <Run FontWeight="SemiBold">About → Settings Folder</Run>
              <Run> to open it in your file manager. Hover any row below for a description of what it does.</Run>
            </TextBlock>
          </Border>

          <!-- Scrollable property grid -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <pgc:PropertyGrid DataContext="{Binding EditCopy}"
                              ShowTitle="False"
                              Margin="0"/>
          </ScrollViewer>
        </DockPanel>
      </TabItem>

      <!-- About tab -->
      <TabItem Header="About">
        <DockPanel Margin="8">

          <!-- Links row -->
          <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Content="GitHub" Command="{Binding OpenGitHubCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Open the project on GitHub (alta01/AzureKeyVaultExplorer)"/>
            <Button Content="Send Feedback" Command="{Binding OpenFeedbackCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Report a bug or suggest a feature on GitHub Issues"/>
            <Button Content="Install Folder" Command="{Binding OpenInstallFolderCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Open the folder where the application binaries are installed"/>
            <Button Content="Settings Folder" Command="{Binding OpenSettingsFolderCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Open the folder containing settings.json and vault configuration files"/>
            <Button Content="Clear Token Cache" Command="{Binding ClearTokenCacheCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Delete all cached Azure authentication tokens. You will be prompted to sign in again."/>
          </WrapPanel>

          <!-- Versions -->
          <TextBlock DockPanel.Dock="Top"
                     Text="Version Information:"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBox DockPanel.Dock="Top"
                   Text="{Binding VersionsInfo}"
                   IsReadOnly="True"
                   FontFamily="Cascadia Mono,Consolas,monospace"
                   FontSize="11"
                   Height="90"
                   AcceptsReturn="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Margin="0,0,0,12"/>

          <!-- License -->
          <TextBlock DockPanel.Dock="Top"
                     Text="License:"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBox Text="{Binding LicenseText}"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   FontSize="11"/>

        </DockPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Microsoft.Vault.Explorer.ViewModels"
        xmlns:pgc="using:Avalonia.PropertyGrid.Controls"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.SubscriptionsManagerView"
        x:DataType="vm:SubscriptionsManagerViewModel"
        Title="Subscriptions Manager"
        Width="920" Height="640"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="8">

    <!-- Status bar -->
    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0" ColumnDefinitions="*,Auto,Auto">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusText}"
                 VerticalAlignment="Center"
                 FontSize="11"
                 Opacity="0.7"/>
      <ProgressBar Grid.Column="1"
                   IsIndeterminate="True"
                   IsVisible="{Binding IsBusy}"
                   Width="140"
                   Height="14"
                   Margin="0,0,12,0"/>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
        <Button Content="OK"
                Width="80"
                IsDefault="True"
                IsEnabled="{Binding CanConfirm}"
                Command="{Binding ConfirmCommand}"
                Click="OkButton_Click"/>
        <Button Content="Cancel"
                Width="80"
                IsCancel="True"
                Click="CancelButton_Click"/>
      </StackPanel>
    </Grid>

    <!-- Account + tenant selectors -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,*" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" Text="Account:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Accounts}"
                SelectedItem="{Binding SelectedAccount}"
                Margin="0,0,12,0"/>
      <TextBlock Grid.Column="2" Text="Tenant:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox Grid.Column="3"
                ItemsSource="{Binding Tenants}"
                SelectedItem="{Binding SelectedTenant}"/>
    </Grid>

    <!-- Main split: subscriptions + vaults (top) | vault details (bottom) -->
    <Grid RowDefinitions="*,4,220">

      <!-- Top: subscription list (left) + vault list (right) -->
      <Grid Grid.Row="0" ColumnDefinitions="*,4,*">

        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="Subscriptions" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ListBox ItemsSource="{Binding Subscriptions}"
                   SelectedItem="{Binding SelectedSubscription}"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent"/>

        <DockPanel Grid.Column="2">
          <TextBlock DockPanel.Dock="Top" Text="Vaults" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ListBox ItemsSource="{Binding Vaults}"
                   SelectedItem="{Binding SelectedVault}"/>
        </DockPanel>
      </Grid>

      <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="Transparent"/>

      <!-- Bottom: access check bar + clean vault details form -->
      <DockPanel Grid.Row="2">
        <!-- Access check status -->
        <StackPanel DockPanel.Dock="Top" Margin="0,2,0,4">
          <ProgressBar IsIndeterminate="True"
                       IsVisible="{Binding IsCheckingAccess}"
                       Height="3"
                       Margin="0,0,0,2"/>
          <TextBlock Text="{Binding AccessCheckResult}"
                     IsVisible="{Binding AccessCheckFailed}"
                     Foreground="OrangeRed"
                     FontSize="11"
                     FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Vault details — simple form, no category/filter buttons -->
        <Border BorderBrush="#33888888" BorderThickness="1" CornerRadius="3"
                Padding="10,8"
                DataContext="{Binding VaultDetails}"
                IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  HorizontalAlignment="Stretch">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"              FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}"    Margin="0,2" TextWrapping="Wrap"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="URI"               FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Uri}"     Margin="0,2" TextWrapping="Wrap"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Location"          FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Location}" Margin="0,2"/>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Subscription"      FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SubscriptionName}" Margin="0,2"/>

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Resource group"    FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ResourceGroupName}" Margin="0,2"/>

              <TextBlock Grid.Row="5" Grid.Column="0" Text="SKU"               FontWeight="SemiBold" Margin="0,2"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Sku}"     Margin="0,2"/>

              <TextBlock Grid.Row="6" Grid.Column="0" Text="Subscription id"   FontWeight="SemiBold" Margin="0,2" Opacity="0.7"/>
              <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SubscriptionId}" Margin="0,2" Opacity="0.7" FontFamily="Monospace" FontSize="11"/>
            </Grid>
          </ScrollViewer>
        </Border>
      </DockPanel>

    </Grid>

  </DockPanel>
</Window>

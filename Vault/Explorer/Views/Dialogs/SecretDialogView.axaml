<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Microsoft.Vault.Explorer.ViewModels"
        xmlns:avalonEdit="using:AvaloniaEdit"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.SecretDialogView"
        x:DataType="vm:SecretDialogViewModel"
        Title="Secret"
        Width="900" Height="620"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="8">

    <!-- Bottom bar: mask toggle + byte counter + OK/Cancel -->
    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0" ColumnDefinitions="Auto,*,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
        <Button Content="Hide / Show"
                Command="{Binding ToggleMaskCommand}"
                IsEnabled="{Binding !IsCertificateMode}"/>
        <Button Content="New Password"
                Command="{Binding NewPasswordCommand}"
                IsEnabled="{Binding !IsCertificateMode}"/>
        <Button Content="New GUID"
                Command="{Binding NewGuidCommand}"
                IsEnabled="{Binding !IsCertificateMode}"/>
        <Button Content="New API Key"
                Command="{Binding NewApiKeyCommand}"
                IsEnabled="{Binding !IsCertificateMode}"/>
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Text="{Binding ByteCounterText}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="11"/>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
        <Button Content="OK"
                Width="80"
                IsDefault="True"
                IsEnabled="{Binding CanSave}"
                Click="OkButton_Click"/>
        <Button Content="Cancel"
                Width="80"
                IsCancel="True"
                Click="CancelButton_Click"/>
      </StackPanel>
    </Grid>

    <!-- Top: name row -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,6" ColumnDefinitions="Auto,*,Auto,*">
      <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <TextBox Grid.Column="1"
               Text="{Binding Name}"
               Watermark="Secret name"
               Margin="0,0,8,0"/>
      <TextBlock Grid.Column="2" Text="Secret kind:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox Grid.Column="3"
                ItemsSource="{Binding SecretKinds}"
                SelectedItem="{Binding SelectedSecretKind}"/>
    </Grid>

    <!-- Versions bar (Edit mode only) -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="6"
                Margin="0,0,0,6"
                IsVisible="{Binding Versions.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
      <TextBlock Text="Version:" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding Versions}"
                SelectedItem="{Binding SelectedVersion}"
                MinWidth="200"/>
    </StackPanel>

    <!-- Error banner -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding NameError}"
               IsVisible="{Binding NameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Foreground="Red"
               FontSize="11"
               Margin="0,0,0,4"/>
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding ValueError}"
               IsVisible="{Binding ValueError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Foreground="Red"
               FontSize="11"
               Margin="0,0,0,4"/>

    <!-- Main split: editor (left) | properties form (right) -->
    <Grid ColumnDefinitions="*,4,260">

      <!-- Value editor panel -->
      <Panel Grid.Column="0">
        <!-- Certificate overlay (shown when IsCertificateMode) -->
        <Border IsVisible="{Binding IsCertificateMode}"
                Background="#18000000"
                CornerRadius="4">
          <TextBlock Text="Certificate — value is read-only"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontStyle="Italic"
                     Opacity="0.6"/>
        </Border>

        <!-- Text editor (AvaloniaEdit) -->
        <avalonEdit:TextEditor x:Name="ValueEditor"
                               IsVisible="{Binding !IsCertificateMode}"
                               FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
                               FontSize="13"
                               ShowLineNumbers="False"
                               WordWrap="True"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"/>
      </Panel>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent"/>

      <!-- Properties form (replaces PropertyGrid) -->
      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8,0,0,0" Spacing="12">

          <!-- Content Type -->
          <StackPanel Spacing="4">
            <TextBlock Text="Content Type" FontSize="11" Opacity="0.6"/>
            <ComboBox ItemsSource="{Binding ContentTypes}"
                      SelectedItem="{Binding SelectedContentType}"
                      HorizontalAlignment="Stretch"/>
          </StackPanel>

          <!-- Enabled -->
          <CheckBox Content="Enabled"
                    IsChecked="{Binding IsEnabled}"
                    Margin="0,0,0,0"/>

          <!-- Valid From -->
          <StackPanel Spacing="4">
            <TextBlock Text="Valid from (UTC)" FontSize="11" Opacity="0.6"/>
            <DatePicker SelectedDate="{Binding ValidFrom}"
                        HorizontalAlignment="Stretch"/>
          </StackPanel>

          <!-- Valid Until -->
          <StackPanel Spacing="4">
            <TextBlock Text="Valid until (UTC)" FontSize="11" Opacity="0.6"/>
            <DatePicker SelectedDate="{Binding ValidUntil}"
                        HorizontalAlignment="Stretch"/>
          </StackPanel>

          <!-- Tags -->
          <StackPanel Spacing="4">
            <TextBlock Text="Tags" FontSize="11" Opacity="0.6"/>
            <TextBlock Text="{Binding TagsSummary}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Opacity="0.8"/>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Grid>

  </DockPanel>
</Window>

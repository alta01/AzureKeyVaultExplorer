<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Microsoft.Vault.Explorer.ViewModels"
        xmlns:pgc="using:Avalonia.PropertyGrid.Controls"
        x:Class="Microsoft.Vault.Explorer.Views.Dialogs.CertificateDialogView"
        x:DataType="vm:CertificateDialogViewModel"
        Title="Certificate"
        Width="860" Height="560"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="8">

    <!-- Bottom buttons -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button Content="OK"
              Width="80"
              IsDefault="True"
              IsEnabled="{Binding CanSave}"
              Click="OkButton_Click"/>
      <Button Content="Cancel"
              Width="80"
              IsCancel="True"
              Click="CancelButton_Click"/>
    </StackPanel>

    <!-- Name row -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,6" ColumnDefinitions="Auto,*">
      <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <TextBox Grid.Column="1"
               Text="{Binding Name}"
               IsReadOnly="{Binding IsNameReadOnly}"
               Watermark="Certificate name"/>
    </Grid>

    <!-- Versions bar (Edit mode) -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="6"
                Margin="0,0,0,6"
                IsVisible="{Binding Versions.Count, Converter={x:Static BoolConverters.IsNotNull}}">
      <TextBlock Text="Version:" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding Versions}"
                SelectedItem="{Binding SelectedVersion}"
                MinWidth="200"/>
    </StackPanel>

    <!-- Main split: cert summary (left) | property grid (right) -->
    <Grid ColumnDefinitions="*,4,340">

      <!-- Certificate summary -->
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="Certificate Details" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <TextBox Text="{Binding CertSummary}"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
                   FontSize="11"
                   Background="Transparent"
                   BorderThickness="0"
                   TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent"/>

      <!-- Property grid -->
      <pgc:PropertyGrid Grid.Column="2"
                        SelectedObject="{Binding PropertyObject}"
                        ShowTitle="False"/>
    </Grid>

  </DockPanel>
</Window>

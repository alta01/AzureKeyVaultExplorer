<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Microsoft.Vault.Explorer.ViewModels"
        xmlns:pgc="using:Avalonia.PropertyGrid.Controls"
        x:Class="Microsoft.Vault.Explorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">

  <DockPanel>

    <!-- ── Menu bar ────────────────────────────────────────────────────── -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGesture="F5"/>
        <Separator/>
        <MenuItem Header="Export to _TSV..." Command="{Binding ExportTsvCommand}"/>
        <Separator/>
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Add _Secret" Command="{Binding AddSecretCommand}"/>
        <MenuItem Header="Add _Certificate from File..." Command="{Binding AddCertFromFileCommand}"/>
        <Separator/>
        <MenuItem Header="_Edit..." Command="{Binding EditCommand}" InputGesture="Enter"/>
        <MenuItem Header="_Toggle Enable/Disable" Command="{Binding ToggleCommand}"/>
        <MenuItem Header="_Delete..." Command="{Binding DeleteCommand}" InputGesture="Delete"/>
        <Separator/>
        <MenuItem Header="Copy _Value" Command="{Binding CopyValueCommand}"/>
        <MenuItem Header="Copy _Link" Command="{Binding CopyLinkCommand}"/>
        <MenuItem Header="_Save to File..." Command="{Binding SaveToFileCommand}"/>
        <Separator/>
        <MenuItem Header="Copy as _Env Var" Command="{Binding CopyAsEnvVarCommand}"/>
        <MenuItem Header="Copy as _Docker Env" Command="{Binding CopyAsDockerEnvCommand}"/>
        <MenuItem Header="Copy as _K8s YAML" Command="{Binding CopyAsK8sYamlCommand}"/>
        <MenuItem Header="Copy _Name" Command="{Binding CopyNameCommand}"/>
        <Separator/>
        <MenuItem Header="_Favorite" Command="{Binding ToggleFavoriteCommand}"/>
      </MenuItem>
      <MenuItem Header="_Settings" Command="{Binding SettingsCommand}"/>
      <MenuItem Header="_Help" Command="{Binding HelpCommand}"/>
    </Menu>

    <!-- ── Vault selector + toolbar ────────────────────────────────────── -->
    <DockPanel DockPanel.Dock="Top" Margin="4,2,4,2">
      <TextBlock Text="Vault:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
      <ComboBox ItemsSource="{Binding VaultAliases}"
                SelectedItem="{Binding SelectedVaultAlias}"
                MinWidth="220"
                Margin="0,0,10,0"/>

      <!-- Separator-style spacer -->
      <Border Width="1" Height="16" Background="#CCCCCC" Margin="0,0,6,0" VerticalAlignment="Center"/>

      <!-- Toolbar buttons (text labels — icons via Phase 4+ asset migration) -->
      <StackPanel Orientation="Horizontal" Spacing="2">
        <Button Content="Refresh"   Command="{Binding RefreshCommand}"        ToolTip.Tip="Refresh vault (F5)" Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <Button Content="+ Secret"  Command="{Binding AddSecretCommand}"       ToolTip.Tip="Add new secret"    Padding="6,2"/>
        <Button Content="+ Cert"    Command="{Binding AddCertFromFileCommand}" ToolTip.Tip="Add certificate from file" Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <Button Content="Edit"      Command="{Binding EditCommand}"     ToolTip.Tip="Edit selected item (Enter)" Padding="6,2"/>
        <Button Content="{Binding ToggleText}" Command="{Binding ToggleCommand}" ToolTip.Tip="Enable or disable item" Padding="6,2"/>
        <Button Content="Delete"    Command="{Binding DeleteCommand}"   ToolTip.Tip="Delete selected item(s) (Del)" Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <Button Content="Copy"      Command="{Binding CopyValueCommand}"    ToolTip.Tip="Copy value to clipboard" Padding="6,2"/>
        <Button Content="Link"      Command="{Binding CopyLinkCommand}"     ToolTip.Tip="Copy vault:// link"     Padding="6,2"/>
        <Button Content="Save"      Command="{Binding SaveToFileCommand}"   ToolTip.Tip="Save to file"           Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <Button Content="ENV"       Command="{Binding CopyAsEnvVarCommand}"    ToolTip.Tip="Copy as ENV=value"       Padding="6,2"/>
        <Button Content="Docker"    Command="{Binding CopyAsDockerEnvCommand}" ToolTip.Tip="Copy as --env ENV=value" Padding="6,2"/>
        <Button Content="K8s"       Command="{Binding CopyAsK8sYamlCommand}"   ToolTip.Tip="Copy as K8s secret YAML" Padding="6,2"/>
        <Button Content="Name"      Command="{Binding CopyNameCommand}"        ToolTip.Tip="Copy item name"          Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <ToggleButton Content="★ Fav"
                      Command="{Binding ToggleFavoriteCommand}"
                      IsChecked="{Binding IsFavorite, Mode=OneWay}"
                      ToolTip.Tip="Toggle favorite" Padding="6,2"/>
        <Separator Width="8" Background="Transparent"/>
        <Button Content="Settings"  Command="{Binding SettingsCommand}" ToolTip.Tip="Open settings" Padding="6,2"/>
        <Button Content="Help"      Command="{Binding HelpCommand}"     ToolTip.Tip="Report an issue" Padding="6,2"/>
      </StackPanel>
    </DockPanel>

    <!-- ── Search row ───────────────────────────────────────────────────── -->
    <DockPanel DockPanel.Dock="Top" Margin="4,2,4,4">
      <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
      <TextBox Name="SearchBox"
               Text="{Binding VaultListViewModel.SearchText}"
               Watermark="Filter items (regex)..."
               MinWidth="260"/>
    </DockPanel>

    <!-- ── Status bar ───────────────────────────────────────────────────── -->
    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto,Auto,Auto,Auto"
          Margin="4,2" Height="24">
      <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                 VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
      <TextBlock Grid.Column="1" Text="{Binding ItemCountText}"
                 VerticalAlignment="Center" Margin="8,0" FontSize="11"/>
      <TextBlock Grid.Column="2" Text="{Binding SelectedCountText}"
                 VerticalAlignment="Center" Margin="8,0" FontSize="11" Opacity="0.8"/>
      <ProgressBar Grid.Column="3"
                   IsIndeterminate="True"
                   IsVisible="{Binding IsBusy}"
                   Width="100" Height="12"
                   Margin="4,0"/>
      <Button Grid.Column="4"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsVisible="{Binding IsBusy}"
              Padding="4,0" FontSize="11"/>
    </Grid>

    <!-- ── Main split: item list (left) | property panel (right) ────────── -->
    <Grid ColumnDefinitions="*,4,300">

      <!-- Item DataGrid -->
      <DataGrid Grid.Column="0"
                Name="ItemsDataGrid"
                ItemsSource="{Binding VaultListViewModel.Items}"
                SelectedItem="{Binding SelectedItem}"
                IsReadOnly="True"
                SelectionMode="Extended"
                CanUserResizeColumns="True"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                AllowDrop="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name"
                              Binding="{Binding Name}"
                              Width="*"
                              MinWidth="140"/>
          <DataGridTextColumn Header="Status"
                              Binding="{Binding Status}"
                              Width="130"/>
          <DataGridTextColumn Header="Updated"
                              Binding="{Binding Updated, StringFormat='{}{0:g}'}"
                              Width="120"/>
          <DataGridTextColumn Header="Expires"
                              Binding="{Binding ExpiresDisplay}"
                              Width="90"/>
          <DataGridTextColumn Header="Changed By"
                              Binding="{Binding ChangedBy}"
                              Width="110"/>
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent"/>

      <!-- Property panel -->
      <pgc:PropertyGrid Grid.Column="2"
                        SelectedObject="{Binding SelectedItem}"
                        ShowTitle="False"/>
    </Grid>

  </DockPanel>
</Window>

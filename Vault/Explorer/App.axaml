<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Microsoft.Vault.Explorer.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <!-- Show tooltips even on disabled buttons so users know what actions require -->
        <Style Selector="Button">
            <Setter Property="ToolTip.ShowOnDisabled" Value="True"/>
        </Style>
        <!-- Keep horizontal scrollbars slim so they don't overlap toolbar button text.
             Fluent theme sets MinHeight internally; override explicitly. -->
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="MaxHeight" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:horizontal /template/ Thumb">
            <Setter Property="MinHeight" Value="4"/>
        </Style>
    </Application.Styles>

    <!-- Active theme ResourceDictionary is merged here at runtime by App.ApplyTheme() -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries />
        </ResourceDictionary>
    </Application.Resources>

</Application>
